---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { FLOWS, sortDocs, toResearchDoc } from "../lib/research";

const entries = await getCollection("research");
const docs = sortDocs(entries.map(toResearchDoc).filter(Boolean));

const flows = FLOWS.map((flow) => {
  const flowDocs = docs.filter((doc) => doc.flow === flow.slug);
  return {
    ...flow,
    total: flowDocs.length,
  };
});
---

<BaseLayout
  title="Private Research Library"
  description="Password-protected research interviews organised by flow."
>
  <section class="grid cols-2">
    {
      flows.map((flow) => (
        <a class="card" href={`/${flow.slug}/`}>
          <p class="eyebrow">{flow.total} interviews</p>
          <h3>{flow.title}</h3>
          <p>{flow.description}</p>
        </a>
      ))
    }
  </section>
</BaseLayout>

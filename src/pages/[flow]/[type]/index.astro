---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  CONTENT_TYPES,
  getFlowBySlug,
  getTypeBySlug,
  sortDocs,
  splitParticipants,
  toResearchDoc,
} from "../../../lib/research";

const flowSlug = Astro.params.flow ?? "";
const typeSlug = Astro.params.type ?? "";
const flow = getFlowBySlug(flowSlug);
const type = getTypeBySlug(typeSlug);

if (!flow || !type) {
  return Astro.redirect("/");
}

const entries = await getCollection("research");
const docs = sortDocs(
  entries
    .map(toResearchDoc)
    .filter((doc) => doc && doc.flow === flow.slug && doc.type === type.slug),
);
---

<BaseLayout title={`${flow.title} ${type.title}`} description={`${type.title} for ${flow.title}.`}>
  <section class="hero">
    <a class="back-link" href={`/${flow.slug}/`} aria-label={`Back to ${flow.title}`}>
      <span aria-hidden="true">←</span>
      <span>Back</span>
    </a>
    <p class="eyebrow">{flow.title}</p>
    <h1>{type.title}</h1>
    <p class="lede">Browse the Markdown-backed {type.title.toLowerCase()} for {flow.title}.</p>
  </section>

  <section class="panel section-block">
    {docs.length ? (
      <div class="plain-list">
        {docs.map((doc) => (
          <div class="doc-row">
            {doc.date && (
              <p class="card-date">
                <strong>{doc.date}</strong>
              </p>
            )}
            {doc.participants && (
              <div class="label-row" aria-label="Participants in the call">
                {splitParticipants(doc.participants).map((participant) => (
                  <span class="meta-label">{participant}</span>
                ))}
              </div>
            )}
            <a href={doc.url}>
              <h3 class="doc-row-title">{doc.title}</h3>
            </a>
            <p class="doc-row-copy card-description">
              {doc.description ?? `Open this ${type.title.toLowerCase().slice(0, -1)}.`}
            </p>
          </div>
        ))}
      </div>
    ) : (
      <p class="empty-note">No {type.title.toLowerCase()} yet.</p>
    )}
  </section>
</BaseLayout>

---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getFlowBySlug, sortDocs, toResearchDoc } from "../../lib/research";

const flowSlug = Astro.params.flow ?? "";
const flow = getFlowBySlug(flowSlug);

if (!flow) {
  return Astro.redirect("/");
}

const entries = await getCollection("research");
const docs = sortDocs(
  entries
    .map(toResearchDoc)
    .filter((doc) => doc && doc.flow === flow.slug && doc.type === "interviews"),
);
---

<BaseLayout title={`${flow.title} Research`} description={flow.description}>
  <article class="doc-page">
    <a class="back-link" href="/" aria-label="Back to Research Library">
      <span aria-hidden="true">←</span>
      <span>Back</span>
    </a>

    <section class="panel section-block">
      <p class="eyebrow">{docs.length} interviews</p>
      <h1 class="section-heading">{flow.title}</h1>
      <p class="lede" style="margin-bottom: 18px;">{flow.description}</p>

      {docs.length ? (
        <div class="grid cols-2">
          {docs.map((doc) => (
            <a class="card interview-card" href={doc.url}>
              <h2 class="card-title card-title-large">{doc.title}</h2>
              {doc.date && (
                <p class="card-date">
                  <strong>{doc.date}</strong>
                </p>
              )}
              <p class="card-description">{doc.description ?? "Open interview."}</p>
            </a>
          ))}
        </div>
      ) : (
        <p class="empty-note">No interviews yet.</p>
      )}
    </section>
  </article>
</BaseLayout>

---
import "@fontsource-variable/geist";
import "../styles/global.css";

type Props = {
  title: string;
  pageTitle?: string;
  description?: string;
};

const {
  title,
  pageTitle = "Research Library",
  description = "Password-protected research notes and interviews.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="/">
          <span class="brand-title">{pageTitle}</span>
        </a>

        <form class="logout-form" method="get" action="/api/logout/">
          <button class="logout-button" type="submit">Log out</button>
        </form>
      </header>

      <slot />
      <div class="footer-space"></div>
    </div>
  </body>
</html>
